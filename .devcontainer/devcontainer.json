{
  "name": "Atelier DevOps - Ngrok 2026",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "installDockerBuildx": true,
      "installDockerComposeSwitch": true
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "forwardPorts": [5000, 4040],
  "portsAttributes": {
    "5000": {
      "label": "Application Flask",
      "onAutoForward": "notify"
    },
    "4040": {
      "label": "Ngrok inspector (si lancé localement)",
      "onAutoForward": "silent"
    }
  },

  "postCreateCommand": "python -m pip install --upgrade pip && echo 'Environnement pret. Lisez le README.md.'",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "github.vscode-github-actions",
        "redhat.vscode-yaml",
        "eamodio.gitlens"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n"
      }
    }
  },

  "remoteUser": "vscode"
}
